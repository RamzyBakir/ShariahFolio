# ============================================================================
# ShariahFolio Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit your .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# API CONFIGURATION (Required)
# ----------------------------------------------------------------------------

# OpenRouter API Key (Get one at https://openrouter.ai/)
# This is required for the AI chat functionality
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model to use (optional, defaults to xiaomi/mimo-v2-flash:free)
OPENROUTER_MODEL=xiaomi/mimo-v2-flash:free

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION (Optional)
# ----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION (Optional - for deployment)
# ----------------------------------------------------------------------------

# Host and port (used when running with uvicorn directly)
# HOST=0.0.0.0
# PORT=8000

# ----------------------------------------------------------------------------
# DEVELOPMENT OPTIONS (Optional)
# ----------------------------------------------------------------------------

# Enable debug mode (more verbose logging)
# DEBUG=false
